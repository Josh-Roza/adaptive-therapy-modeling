<?xml version="1.0" encoding="utf-8"?>
<model version="NetLogo 7.0.3" snapToGrid="false">
  <code><![CDATA[;;assuming patch getting resource in last tick is still eligible for next one
;;random patches get the resource
breed [ drugts drugt ]
breed [ resourcets resourcet ]
patches-own [ is-tumor? starved-for just-died? is-blood-vessel?]
globals [tumor-burden tumor-burden-threshold bolusTick c1count c2count total-drug delta total-invasion invasionPResistant]


to setup
  clear-all
  set total-invasion 0
  set invasionPResistant 1 - proliferationP-DP
  ;let ccount 1
  if cell-count = 0 [stop]
  ; size of the tumor growing space doesn't go smaller when blood vessel is added
  resize-world min-pxcor (max-pycor + blood-vessel-width)  min-pycor max-pycor
  let scount round ( cell-count * PRO-to-DP )
  let rcount cell-count - scount
  set tumor-burden-threshold max-pycor * (max-pxcor - blood-vessel-width) * pi * 0.9
  ;clones should be at the center
  set bolusTick 0
  ;set drugMolecule 0
  ;random-seed 100
  ; make everything from black to white
  ask patches [
    set pcolor white
    set is-tumor? false
    set is-blood-vessel? false
  ]

  ask patches with [pxcor > (max-pxcor - blood-vessel-width)] [
    set is-blood-vessel? true
    set pcolor pink
  ]

  ;create resource resourcets of resource
  ask n-of resource patches with [not is-blood-vessel?] [
    sprout-resourcets 1 [
    set shape "food"
    set color green
    set size 1]
  ]

  ask patch 0 0 [
    set is-tumor? true
    set pcolor blue
  ]

  while [ count patches with [pcolor = blue] < cell-count ] [
    let can-grow patches with [pcolor != blue and pcolor != pink and any? neighbors with [pcolor = blue]]
    if any? can-grow [
      ask one-of can-grow [
        set is-tumor? true
        set pcolor blue
      ]
    ]
  ]

  ask n-of scount patches with [ is-tumor? ] [ set pcolor orange ]
  ask patches with [pcolor = blue] [ set pcolor black ]


  set c1count scount
  set c2count rcount


  reset-ticks
end

to addBolus
  set bolusTick ticks + nextBolusTime
end

to go
  set tumor-burden count patches with [ is-tumor? ]
  set c1count count patches with [pcolor = orange]
  set c2count count patches with [pcolor = black]
  set delta abs ( tumor-burden - adaptive-burden-threshold )
  if tumor-burden > tumor-burden-threshold or tumor-burden = 0 or total-invasion >= invasion-threshold [ stop ]

  ; every 7th tick give bolus if tumor-burden is high

  ifelse adaptive-therapy [
    set drugMolecule 0
    ; sensitive count > burden threshold
    if c1count > adaptive-burden-threshold and ticks mod 7 = 0  and count drugts < max-drug [
      giveDrugs bolusAmount
    ]
  ]
  [
    ifelse bolusTick > 0 and ticks mod bolusTick = 0 [
      giveDrugs bolusAmount
    ]
    [
      if ticks > startTime and ( ticks - startTime ) mod timeInterval = 0 [
        giveDrugs drugMolecule
      ]
    ]
  ]

  ;for clones
  ask patches with [ is-tumor? and not is-blood-vessel?] [

    set just-died? false

    ;for clones with resource
    ifelse count resourcets-here = 1 [
      ask resourcets-here [die]
      set starved-for 0

    ]
    ;else part for clones without resource
    [
      if starved-for != -1 [ set starved-for starved-for + 1 ]
      if starved-for > starvingThreshold [
        set pcolor white
        set just-died? true
        set is-tumor? false
      ]

    ]

    ;drug sensitive vs. drug resistant
    ifelse pcolor = orange [
      ;ifelse count drugts-here = 1 [
       if count drugts-here >= 1 [
        ask drugts-here [die]
        set just-died? true
        set is-tumor? false
        set pcolor white
        ;sprout 1 [ set color pink ]
      ]
      if not just-died? and random-float 1 < proliferationP-PRO [ replicate orange ]
    ]
    ; else part
    [
      if not just-died? and random-float 1 < proliferationP-DP [ replicate black ]
    ]
  ]

  ask resourcets [
    if any? neighbors with [count resourcets-here = 0 and not is-blood-vessel? ] [move-to one-of neighbors with [count resourcets-here = 0 and not is-blood-vessel? ]]
  ]



  ask drugts [
    ;if count neighbors with [count drugts-here = 0] != 0 [
      move-to one-of neighbors with [ not is-blood-vessel? ];with [count drugts-here = 0]
    ;]
    if round abs xcor = max-pxcor - blood-vessel-width or round abs ycor = max-pycor  [die]
  ]


  let resourcet-consumed resource - count resourcets

  let m min list resourcet-consumed resourceRate

  ;assuming patch getting resource in last tick is still eligible for next one
  ;again random patches get the resource
  ask n-of m patches with [count resourcets-here = 0 and not is-blood-vessel? ] [
    sprout-resourcets 1 [
      set shape "food"
      set color green
      set size 1
    ]
  ]

  tick
end

to giveDrugs [dm]
  set total-drug total-drug + dm
  ask n-of dm patches with [ not is-blood-vessel? ] [
      sprout-drugts 1 [
        set shape "bug"
        ;set shape "ball baseball"
        set color blue
        set size 1
      ]
    ]
end

to replicate [col]
  ifelse col = orange [
    let nc count neighbors with [pcolor = white]
    if nc > 0 [
      ask one-of neighbors with [pcolor = white] [
        initiate-new col
      ]
    ]
  ]
 ; else part for col= black
  ; once penetrates into blood vessel, no need of invasion probability and it tries to proliferate there itself and don't cross the boundary again
  ; how about starvation?
  [
    let nc count neighbors with [pcolor = white or pcolor = pink]
    if nc > 0 [
      ask one-of neighbors with [pcolor = white or pcolor = pink]
      [
        ifelse pcolor = pink
        [
          ifelse random-float 1 < invasionP-DP
          [
            set total-invasion total-invasion + 1
            initiate-new red
          ]
          [
            let nw count neighbors with [pcolor = white]
            if nw > 0
            [
              ask one-of neighbors with [pcolor = white] [ initiate-new col ]
            ]
          ]
        ]
        ;white
        [
            initiate-new col
        ]
      ]
    ]
  ]

end

to initiate-new [col]
  set pcolor col
  set is-tumor? true
  ifelse col = red [set starved-for -1][set starved-for 0]
end]]></code>
